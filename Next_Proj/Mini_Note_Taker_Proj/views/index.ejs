<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">

        <form action="/create" method="post">
            <input class="block px-5 mt-2 py-2 bg-zinc-800 w-full rounded-md outline-none" type="text"
                placeholder="Task name" name="title" />
            <textarea class="block mt-2 resize-none px-5 py-2 bg-zinc-800 w-full rounded-md outline-none"
                placeholder="write your task details" name="details"></textarea>
            <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Create tasks" />

        </form>

        <div class="tasks mt-10 flex gap-5 flex-wrap">

            <% if (files.length >0){ %>
                <% files.forEach((val)=>{ %>

            <div class="task  min-w-72  px-3 py-4 bg-zinc-800 rounded-md">
                <h1 class="text-3xl tracking-tighter "><%= val %></h1>
                <div class="flex w-full mt-3 justify-between items-center ">
                <a class="text-blue-500 inline-block " href="/files/<%= val %>">Read more</a>
                <a class="text-zinc-600" href="/edit/<%= val %>">Edit filename</a>

                </div>
                
            </div>
                <%   }) %>

            <% } else { %>
                <h3>No Taks Yet.</h3>
            <% } %>

            
            
        </div>

    </div>
    </div>
</body>

</html>