<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">

        <a  class="text-blue-500 inline-block mb-10" href="/">Go back to Home</a>
        
        <form action="/edit" method="post">
           
            <input type="hidden" name="previous" value="<%= filename %>" />
<p class="block px-5 text-zinc-400 mt-2 py-2 bg-zinc-800 w-1/4 rounded-md outline-none"><%= filename %></p>

            <input  class="block mt-2 resize-none px-5 py-2 mt-2 bg-zinc-800 w-1/4 rounded-md outline-none" placeholder="New name" name="new">
            <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type="submit" value="Update name" />

        </form>

    </div>
</body>

</html>